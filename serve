#!/usr/bin/env bash
# Build the app and run it the way production should: bundled server + prebuilt
# web assets, no dev server, no browser launch.
set -euo pipefail

cd "$(dirname "$0")"

# 5173 is also the Vite dev server port, so `npm run dev` and this cannot both be
# up at once. In production there is no Vite: this process serves API + web alone.
PORT="${TORLINK_PORT:-5173}"

if [ ! -d node_modules ]; then
  echo "==> installing dependencies"
  npm ci
fi

echo "==> building server + web"
npm run build

echo "==> starting torlink on 127.0.0.1:$PORT"
export TORLINK_PORT="$PORT"
export TORLINK_NO_OPEN=1
exec node dist/index.js
